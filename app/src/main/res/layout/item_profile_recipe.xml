<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <ImageView
        android:id="@+id/ivRecipeThumb"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/foodtok_divider"
        android:contentDescription="Recipe thumbnail"
        android:scaleType="centerCrop" />

    <!-- Long-press interaction overlay for Saved tab (hidden by default) -->
    <LinearLayout
        android:id="@+id/overlayInteractions"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/foodtok_overlay"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Like -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/btnOverlayLike"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Like"
                android:src="@drawable/ic_like"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Like"
                android:textColor="@android:color/white"
                android:textSize="9sp" />

        </LinearLayout>

        <!-- Save -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/btnOverlaySave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save"
                android:src="@drawable/ic_save"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Save"
                android:textColor="@android:color/white"
                android:textSize="9sp" />

        </LinearLayout>

        <!-- Not Interested -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/btnOverlayDislike"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Not Interested"
                android:src="@drawable/ic_thumbs_down"
                android:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nope"
                android:textColor="@android:color/white"
                android:textSize="9sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
