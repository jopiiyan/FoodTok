<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/foodtok_cream_dark"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="90dp">

        <!-- Recipe Title -->
        <TextView
            android:id="@+id/recipeDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/foodtok_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Author -->
        <TextView
            android:id="@+id/recipeDetailAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/foodtok_text_secondary"
            android:textSize="14sp" />

        <!-- Prep / Cook time chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/prepTimeChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_prep_time"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/foodtok_text_on_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cookTimeChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_cook_time"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/foodtok_text_on_dark"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nutrients chip -->
        <TextView
            android:id="@+id/nutrientsChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/chip_nutrients"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/foodtok_text_on_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Allergen Alert Banner -->
        <TextView
            android:id="@+id/allergenBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/banner_allergen"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:textColor="@color/foodtok_text_on_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Ingredients Section Header -->
        <TextView
            android:id="@+id/ingredientsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:textColor="@color/foodtok_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Ingredients List -->
        <TextView
            android:id="@+id/ingredientsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="6dp"
            android:textColor="@color/foodtok_text_primary"
            android:textSize="14sp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/foodtok_divider" />

        <!-- Instructions Section Header -->
        <TextView
            android:id="@+id/instructionsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/foodtok_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Instructions List -->
        <TextView
            android:id="@+id/instructionsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="8dp"
            android:textColor="@color/foodtok_text_secondary"
            android:textSize="14sp" />

        <!-- Generate AI Insights Button -->
        <Button
            android:id="@+id/generateAiButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="✦ Generate AI Insights"
            android:textColor="@color/foodtok_text_on_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:visibility="visible" />

        <!-- Calories  -->
        <TextView
            android:id="@+id/caloriesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
