<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ExoPlayer surface — player is attached/detached by FeedVideoPlayerPool -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/recipeVideoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#2A2A2A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="zoom"
        app:use_controller="false" />

    <!-- Center play indicator: visible only while paused. Tap on video toggles. -->
    <ImageView
        android:id="@+id/playPauseOverlay"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:contentDescription="Paused"
        android:src="@drawable/ic_play_overlay"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bottom-left: username, author, allergen warning, title, tags -->
    <LinearLayout
        android:id="@+id/bottomLeftInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="72dp"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bottomRightActions"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Username from User.name -->
        <TextView
            android:id="@+id/usernameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:textColor="#BBBBBB"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/authorNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/allergenWarningText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Contains allergens"
            android:textColor="#E85D3A"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/recipeTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/recipeTagsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Right side: profile pic + action buttons — anchored to the bottom
         so they sit in the comfortable thumb-reach zone and align with the
         caption row on the left. -->
    <LinearLayout
        android:id="@+id/bottomRightActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="32dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/ic_profile_placeholder"
                android:contentDescription="Author avatar"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/followPlusButton"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@android:color/white"
                android:contentDescription="Follow"
                android:padding="2dp"
                android:src="@android:drawable/ic_input_add"
                android:visibility="gone" />

        </FrameLayout>

        <ImageView
            android:id="@+id/likeButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="Like"
            android:padding="2dp"
            android:src="@drawable/ic_like" />

        <TextView
            android:id="@+id/likeCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <ImageView
            android:id="@+id/commentButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="Comment"
            android:padding="2dp"
            android:src="@drawable/ic_comment" />

        <TextView
            android:id="@+id/commentCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <ImageView
            android:id="@+id/saveButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="Save"
            android:padding="2dp"
            android:src="@drawable/ic_save" />

        <TextView
            android:id="@+id/saveCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#99000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <ImageView
            android:id="@+id/notInterestedButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:contentDescription="Not Interested"
            android:padding="2dp"
            android:src="@drawable/ic_thumbs_down" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
